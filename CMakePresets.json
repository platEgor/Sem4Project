{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs2026-x64",
      "displayName": "Visual Studio 2026 x64",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/SFML",
        "SFML_STATIC_LIBRARIES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release"
    }
  ]
}